# Copy to deploy/mm.env (gitignored) and edit before enabling polymarket-mm.service.
# MM_CONTRACTS = comma-separated indices into config.live.json "contracts".
MM_CONTRACTS=2
MM_SIZE=20
MM_HALF_SPREAD=0.02
MM_MAX_ORDER=19
MM_MAX_TOTAL=22
MM_INTERVAL=12
# GTD: seconds until a resting order auto-expires if this process/box goes silent.
MM_GTD=120
